<Window x:Class="Zen_Music.AddArtistPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upload Artist Page"
        Width="1200" Height="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        
        <!-- Стил за TextBox -->
        <Style x:Key="ZenTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#D2D2DC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                        CornerRadius="6"
                        Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стил за основен бутон (Cancel / Save) -->
        <Style x:Key="ZenButton" TargetType="Button">
            <Setter Property="Background" Value="#8EBBFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                        CornerRadius="8" Padding="20,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#6AA3F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4A83D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ZenLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ZenComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#D2D2DC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <!-- Външен контейнер -->
    <Border Background="#1A1D27" CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <!-- Заглавна лента за drag -->
            <Border Height="40" VerticalAlignment="Top"
                    Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseDown"
                    Cursor="SizeAll">
                <TextBlock Text="Upload Artist Page"
                    Foreground="#7B80A8"
                    FontSize="12" Margin="20,0,0,0"
                    VerticalAlignment="Center"/>
            </Border>

            <!-- Вътрешен панел -->
            <Border Margin="40,50,40,40"
                    Background="#22263A"
                    CornerRadius="12">
                <Grid Margin="50,40,50,40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заглавие -->
                    <TextBlock Grid.Row="0"
                               Text="Upload Artist"
                               FontFamily="Segoe UI"
                               FontSize="45" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30"/>
                    
                    <!-- Основна решетка с форма -->
                    <Grid Grid.Row="1" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ══ ЛЯВА КОЛОНА ══ -->
                        <StackPanel Grid.Column="0" Margin="0,0,30,0">
                            
                            <!-- Profile picture -->
                            <Grid Margin="0,0,0,40">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Profile picture:" Style="{StaticResource ZenLabel}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Border Width="150" Height="150" Background="#D2D2DC" CornerRadius="10" ClipToBounds="True">
                                        <Image x:Name="imageArtist" Stretch="UniformToFill"/>
                                    </Border>
                                    <Button Content="Upload" Style="{StaticResource ZenButton}"
                                            Width="100" Height="40" Margin="50,0,0,60" VerticalAlignment="Bottom"
                                            Click="buttonUpload_Click"/>
                                </StackPanel>
                            </Grid>

                            <!-- Artist name -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Artist name:" Style="{StaticResource ZenLabel}"/>
                                <TextBox x:Name="textBoxArtistName" Grid.Column="1" Style="{StaticResource ZenTextBox}"/>
                            </Grid>

                        </StackPanel>

                        <!-- ══ ДЯСНА КОЛОНА ══ -->
                        <StackPanel Grid.Column="1" Margin="30,50,20,0">
                            
                            <!-- Description -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Description:" Style="{StaticResource ZenLabel}"
                                          VerticalAlignment="Top" Margin="0,10,0,0"/>
                                <TextBox x:Name="textBoxDescription" Grid.Column="1"
                                         Height="160"
                                         Style="{StaticResource ZenTextBox}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalContentAlignment="Top"
                                         Padding="10,8"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                            </Grid>
                            
                        </StackPanel>
                    </Grid>

                    <!-- Бутони Cancel / Save -->
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Content="Cancel" Style="{StaticResource ZenButton}"
                                Background="#7B80A8" Width="160" Height="50"
                                Margin="0,0,30,0" Click="buttonCancel_Click"/>
                        <Button Content="Save Artist" Style="{StaticResource ZenButton}"
                                Width="160" Height="50" Click="buttonSave_Click"/>
                    </StackPanel>
                    
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
