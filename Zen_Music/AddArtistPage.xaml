<Window x:Class="Zen_Music.AddArtistPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upload Artist Page"
        Width="860" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="BgOuter"      Color="#1A1D27"/>
        <SolidColorBrush x:Key="BgPanel"      Color="#22263A"/>
        <SolidColorBrush x:Key="AccentBlue"   Color="#8EBBFF"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#EAEAF5"/>
        <SolidColorBrush x:Key="TextLabel"    Color="#EAEAF5"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#7B80A8"/>
        <SolidColorBrush x:Key="InputBg"      Color="#DDDCDC"/>
        <SolidColorBrush x:Key="InputBorder"  Color="#DDDCDC"/>
        <SolidColorBrush x:Key="AvatarBg"     Color="#3A3F60"/>

        <!-- Стил за TextBox -->
        <Style x:Key="ZenTextBox" TargetType="TextBox">
            <Setter Property="Background"        Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"        Value="#22263A"/>
            <Setter Property="CaretBrush"        Value="{StaticResource AccentBlue}"/>
            <Setter Property="BorderBrush"       Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стил за основен бутон (Cancel / Save) -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">

                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="22" Padding="32,10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#82BEFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5495D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стил за малък бутон (Upload / Select …) -->
        <Style x:Key="SmallBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16" Padding="18,7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#82BEFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5495D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Външен контейнер -->
    <Border Background="{StaticResource BgOuter}" CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <!-- Заглавна лента за drag -->
            <Border Height="36" VerticalAlignment="Top"
                    Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseDown"
                    Cursor="SizeAll">
                <TextBlock Text="Upload Artist Page"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="11" Margin="16,0,0,0"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Вътрешен панел -->
            <Border Margin="20,46,20,10"
                    Background="{StaticResource BgPanel}"
                    CornerRadius="12">

                <Grid Margin="40,28,40,28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Заглавие -->
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="*"/>
                        <!-- Съдържание -->
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="Auto"/>
                        <!-- Бутони -->
                    </Grid.RowDefinitions>

                    <!-- Заглавие -->
                    <TextBlock Grid.Row="0"
                               Text="Upload Artist"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="28" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,12,0,12" Grid.RowSpan="2"/>

                    <!-- Основна решетка с форма -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ══ ЛЯВА КОЛОНА ══ -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">

                            <!-- Profile picture -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Profile picture:"
                                           Foreground="{StaticResource TextLabel}"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Top"
                                           Width="130" Margin="0,18,0,0"/>

                                <!-- Кръгла снимка -->
                                <Border Grid.Column="1"
                                        Width="72" Height="72"
                                        CornerRadius="36"
                                        Background="#DDDCDC"
                                        ClipToBounds="True"
                                        HorizontalAlignment="Left" Margin="20,-4,0,4">
                                    <Image x:Name="imageArtist" Stretch="UniformToFill" Margin="7,0,1,0"/>
                                </Border>

                                <Button Grid.Column="1"
                                        Content="Upload"
                                        Style="{StaticResource SmallBtn}"
                                        Click="buttonUpload_Click"
                                        VerticalAlignment="Top"
                                        Margin="122,16,24,0"/>
                            </Grid>

                            <!-- Artist name -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Artist name:"
                                           Foreground="{StaticResource TextLabel}"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Top"
                                           Width="130" Margin="0,27,0,0"/>
                                <TextBox x:Name="textBoxArtistName"
                                         Grid.Column="1"
                                         Height="36"
                                         Style="{StaticResource ZenTextBox}" Margin="0,18,0,-18"/>
                            </Grid>

                            <!-- Add songs -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                            </Grid>

                        </StackPanel>

                        <!-- ══ ДЯСНА КОЛОНА ══ -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" >

                            <!-- Add albums -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                            </Grid>

                            <!-- Description -->
                            <StackPanel>
                                <TextBlock Text="Description:"
                                           Foreground="{StaticResource TextLabel}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <TextBox x:Name="textBoxDescription"
                                         Height="120"
                                         Style="{StaticResource ZenTextBox}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalContentAlignment="Top"
                                         Padding="10,8"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                            </StackPanel>

                        </StackPanel>
                    </Grid>

                    <!-- Бутони Cancel / Save -->
                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                >
                        <Button Content="Cancel"
                                Style="{StaticResource PrimaryBtn}"
                                Width="150"
                                Click="buttonCancel_Click"/>
                        <Button Content="Save"
                                Style="{StaticResource PrimaryBtn}"
                                Width="150"
                                Click="buttonSave_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
