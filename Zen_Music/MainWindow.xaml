<Window x:Class="Zen_Music.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin Select Page"
        Width="1200" Height="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="BgOuter"       Color="#1A1D27"/>
        <SolidColorBrush x:Key="BgPanel"       Color="#22263A"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#8EBBFF"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#EAEAF5"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#7B80A8"/>
        <SolidColorBrush x:Key="IconBg"        Color="#2E3354"/>

        <!-- Стил за ActionButton (редовете с икона + текст) -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="12" Padding="16,14">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2E45"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#343860"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Leave Admin Mode бутон -->
        <Style x:Key="LeaveBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground"      Value="#FFF"/>
            <Setter Property="FontSize"        Value="18"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="28" Padding="48,16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#82BEFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5495D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgOuter}" CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="50" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <!-- Title bar -->
            <Border Height="40" VerticalAlignment="Top" Background="Transparent" Cursor="SizeAll">
                <TextBlock Text="Admin Select Page" Foreground="{StaticResource TextSecondary}"
                           FontSize="12" Margin="20,0,0,0" VerticalAlignment="Center"/>
            </Border>

            <Border Margin="40,50,40,40" Background="{StaticResource BgPanel}" CornerRadius="16">
                <Grid Margin="50,40,50,40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заглавие -->
                    <TextBlock Grid.Row="0" HorizontalAlignment="Center">
                        <Run Text="Welcome back, " Foreground="{StaticResource TextPrimary}"
                             FontSize="36" FontWeight="Bold"/>
                        <Run Text="Administrator" Foreground="{StaticResource AccentBlue}"
                             FontSize="36" FontWeight="Bold"/>
                        <Run Text="!" Foreground="{StaticResource TextPrimary}"
                             FontSize="36" FontWeight="Bold"/>
                    </TextBlock>

                    <!-- 3 колони с бутони -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ── Songs ── -->
                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock Text="Songs"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="24" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,30"/>

                            <!-- Add Song -->
                            <Button Style="{StaticResource ActionBtn}"
                                    Click="btnTestUpload_Click" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="48" Height="48" CornerRadius="24"
                                            Background="{StaticResource IconBg}"
                                            Margin="0,0,16,0">
                                        <TextBlock Text="+" Foreground="{StaticResource AccentBlue}"
                                                   FontSize="28" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Margin="0,0,0,2"/>
                                    </Border>
                                    <TextBlock Text="Add Song"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="18" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Update Song -->
                            <Button Style="{StaticResource ActionBtn}"
                                    Click="btnTestUpdate_Click" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="48" Height="48" CornerRadius="24"
                                            Background="{StaticResource IconBg}"
                                            Margin="0,0,16,0">
                                        <TextBlock Text="↻" Foreground="{StaticResource AccentBlue}"
                                                   FontSize="24" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Update Song"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="18" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Delete Song -->
                            <Button Style="{StaticResource ActionBtn}"
                                    Click="btnTestDelete_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="48" Height="48" CornerRadius="24"
                                            Background="{StaticResource IconBg}"
                                            Margin="0,0,16,0">
                                        <TextBlock Text="✕" Foreground="#F28B82"
                                                   FontSize="20" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Delete Song"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="18" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- ── Albums ── -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock Text="Albums"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="24" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,30"/>

                            <!-- Add Album -->
                            <Button Style="{StaticResource ActionBtn}"
                                    Click="btnTestUploadAlbum_Click" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="48" Height="48" CornerRadius="24"
                                            Background="{StaticResource IconBg}"
                                            Margin="0,0,16,0">
                                        <TextBlock Text="+" Foreground="{StaticResource AccentBlue}"
                                                   FontSize="28" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Margin="0,0,0,2"/>
                                    </Border>
                                    <TextBlock Text="Add Album"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="18" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Update Album -->
                            <Button Style="{StaticResource ActionBtn}" Margin="0,0,0,12" Click="Button_Click_1">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="48" Height="48" CornerRadius="24"
                                            Background="{StaticResource IconBg}"
                                            Margin="0,0,16,0">
                                        <TextBlock Text="↻" Foreground="{StaticResource AccentBlue}"
                                                   FontSize="24" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Update Album"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="18" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Delete Album -->
                            <Button Style="{StaticResource ActionBtn}" Click="Button_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="48" Height="48" CornerRadius="24"
                                            Background="{StaticResource IconBg}"
                                            Margin="0,0,16,0">
                                        <TextBlock Text="✕" Foreground="#F28B82"
                                                   FontSize="20" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Delete Album"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="18" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- ── Artists ── -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock Text="Artists"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="24" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,30"/>

                            <!-- Add Artist -->
                            <Button Style="{StaticResource ActionBtn}"
                                    Click="btnTestAddArtist_Click" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="48" Height="48" CornerRadius="24"
                                            Background="{StaticResource IconBg}"
                                            Margin="0,0,16,0">
                                        <TextBlock Text="+" Foreground="{StaticResource AccentBlue}"
                                                   FontSize="28" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Margin="0,0,0,2"/>
                                    </Border>
                                    <TextBlock Text="Add Artist"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="18" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Update Artist -->
                            <Button Style="{StaticResource ActionBtn}"
                                    Click="btnTestUpdateArtist_Click" Margin="0,0,0,12">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="48" Height="48" CornerRadius="24"
                                            Background="{StaticResource IconBg}"
                                            Margin="0,0,16,0">
                                        <TextBlock Text="↻" Foreground="{StaticResource AccentBlue}"
                                                   FontSize="24" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Update Artist"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="18" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Delete Artist -->
                            <Button Style="{StaticResource ActionBtn}"
                                    Click="btnTestDeleteArtist_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="48" Height="48" CornerRadius="24"
                                            Background="{StaticResource IconBg}"
                                            Margin="0,0,16,0">
                                        <TextBlock Text="✕" Foreground="#F28B82"
                                                   FontSize="20" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Delete Artist"
                                               Foreground="{StaticResource TextPrimary}"
                                               FontSize="18" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Leave Admin Mode бутон -->
                    <StackPanel Grid.Row="4" HorizontalAlignment="Center">
                        <Button Style="{StaticResource LeaveBtn}" Click="Button_Click_2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="❮ " FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text="Leave Admin Mode" FontSize="18" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>