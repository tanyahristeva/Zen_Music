<Window x:Class="Zen_Music.UploadSongPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upload Song Page - ZEN Music"
        Width="820" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#24293E">

    <Window.Resources>
        <!-- Base button style -->
        <Style x:Key="ZenButton" TargetType="Button">
            <Setter Property="Background" Value="#8EBBFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="12,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#6AA3F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4A83D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label style -->
        <Style x:Key="ZenLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="ZenTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#D2D2DC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
           <Setter Property="Padding" Value="8,0"/> 
            <Setter Property="Height" Value="32"/> 
         <Setter Property="VerticalContentAlignment" Value="Center"/> 
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox style -->
        <Style x:Key="ZenComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#D2D2DC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
           
        </Style>
    </Window.Resources>

    <Grid Margin="30,25,30,25">
        <Grid.RowDefinitions>
            <RowDefinition Height="55"/>
            <!-- Title -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="60"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ===== TITLE ===== -->
        <TextBlock Grid.Row="0"
                   Text="Upload Song"
                   FontFamily="Segoe UI"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"/>

        <!-- ===== CONTENT ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!-- Left -->
                <ColumnDefinition Width="*"/>
                <!-- Right -->
            </Grid.ColumnDefinitions>

            <!-- ===== LEFT COLUMN ===== -->
            <StackPanel Grid.Column="0" Margin="0,0,20,0" VerticalAlignment="Top">

                <!-- Cover picture row -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Cover picture:" Style="{StaticResource ZenLabel}" Margin="0,0,0,0"/>
                    <Border Grid.Column="1"
                            Width="100" Height="100"
                            Background="#D2D2DC"
                            CornerRadius="6"
                            HorizontalAlignment="Left">
                        <Image x:Name="imgCover" Stretch="Uniform"/>
                    </Border>
                    <Button Grid.Column="2"
                            x:Name="btnUpload"
                            Content="Upload"
                            Style="{StaticResource ZenButton}"
                            Width="90" Height="36"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="8,4,0,0"
                            Click="btnUpload_Click"/>
                </Grid>

                <!-- Song name -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Song name:" Style="{StaticResource ZenLabel}"/>
                    <TextBox Grid.Column="1" x:Name="txtSongName" Style="{StaticResource ZenTextBox}"/>
                </Grid>

                <!-- Artist name -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Artist name:" Style="{StaticResource ZenLabel}"/>
                    <ComboBox Grid.Column="1" x:Name="cmbArtist" Style="{StaticResource ZenComboBox}"
                              DisplayMemberPath="Name" SelectedValuePath="ID"/>
                </Grid>

            </StackPanel>

            <!-- ===== RIGHT COLUMN ===== -->
            <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Top">

                <!-- Add file -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Add file:" Style="{StaticResource ZenLabel}"/>
                    <StackPanel Grid.Column="1">
                        <Button x:Name="btnSelectFile"
                                Content="Select file"
                                Style="{StaticResource ZenButton}"
                                Width="110" Height="36"
                                HorizontalAlignment="Left"
                                Click="btnSelectFile_Click" RenderTransformOrigin="0.461,1.038"/>
                        <TextBlock x:Name="lblFileName"
                                   Text="No file selected"
                                   Foreground="#BBBBBB"
                                   FontFamily="Segoe UI"
                                   FontSize="11"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Duration -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Duration:" Style="{StaticResource ZenLabel}"/>
                    <TextBox Grid.Column="1" x:Name="txtDuration"
                             Style="{StaticResource ZenTextBox}"
                             ToolTip="Format: mm:ss (e.g. 3:41)"/>
                </Grid>

                <!-- Genre -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Genre:" Style="{StaticResource ZenLabel}"/>
                    <ComboBox Grid.Column="1" x:Name="cmbGenre" Style="{StaticResource ZenComboBox}"
                              DisplayMemberPath="Name" SelectedValuePath="ID"/>
                </Grid>

                <!-- Album -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Album:" Style="{StaticResource ZenLabel}"/>
                    <ComboBox Grid.Column="1" x:Name="cmbAlbum" Style="{StaticResource ZenComboBox}"
                              DisplayMemberPath="Title" SelectedValuePath="ID"
                              SelectionChanged="cmbAlbum_SelectionChanged"/>
                </Grid>

                <!-- Year (auto-filled) -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Year:" Style="{StaticResource ZenLabel}"/>
                    <TextBox Grid.Column="1" x:Name="txtYear"
                             Style="{StaticResource ZenTextBox}"
                             IsReadOnly="True"
                             Background="#B8B8C8"/>
                </Grid>

            </StackPanel>
        </Grid>

        <!-- ===== BUTTONS ===== -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <Button x:Name="btnCancel"
                    Content="Cancel"
                    Style="{StaticResource ZenButton}"
                    Width="120" Height="42"
                    Margin="0,0,20,0"
                    Click="btnCancel_Click"/>
            <Button x:Name="btnSave"
                    Content="Save"
                    Style="{StaticResource ZenButton}"
                    Width="120" Height="42"
                    Click="btnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>