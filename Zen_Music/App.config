<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
	<connectionStrings>
		<add name="MusicDb"
			 connectionString="Data Source=(localdb)\MSSQLLocalDB;Initial Catalog=MusicAppDb;Integrated Security=True;Connect Timeout=30;Encrypt=False"
			 providerName="System.Data.SqlClient" />
	</connectionStrings>
</configuration>