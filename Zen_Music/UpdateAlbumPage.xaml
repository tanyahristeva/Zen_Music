<Window x:Class="Zen_Music.AlbumPages.UpdateAlbumPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Album Page"
        Width="720" Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="BgOuter"       Color="#1A1D27"/>
        <SolidColorBrush x:Key="BgPanel"       Color="#22263A"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#8EBBFF"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#EAEAF5"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#7B80A8"/>
        <SolidColorBrush x:Key="InputBg"       Color="#DDDCDC"/>
        <SolidColorBrush x:Key="InputBorder"   Color="#3A3F60"/>
        <SolidColorBrush x:Key="AvatarBg"      Color="#DDDCDC"/>

        <!-- ComboBox стил -->
        <Style x:Key="ZenCombo" TargetType="ComboBox">
            <Setter Property="Background"        Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"        Value="#000000"/>
            <Setter Property="BorderBrush"       Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="Height"            Value="36"/>
            <Setter Property="Padding"           Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground"             Value="#000000"/>
                        <Setter Property="Background"             Value="Transparent"/>
                        <Setter Property="Padding"                Value="8,0"/>
                        <Setter Property="Height"                 Value="32"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2E3354"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#343860"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox стил -->
        <Style x:Key="ZenTextBox" TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="CaretBrush"      Value="{StaticResource AccentBlue}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Основен бутон -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground"      Value="#FFF"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="22" Padding="32,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#82BEFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5495D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="16" Padding="18,7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#82BEFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgOuter}" CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <!-- Title bar -->
            <Border Height="36" VerticalAlignment="Top" Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseDown" Cursor="SizeAll">
                <TextBlock Text="Update Album Page" Foreground="{StaticResource TextSecondary}"
                           FontSize="11" Margin="16,0,0,0" VerticalAlignment="Center"/>
            </Border>

            <Border Margin="20,36,20,20" Background="{StaticResource BgPanel}" CornerRadius="12">
                <Grid Margin="40,24,40,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заглавие -->
                    <TextBlock Grid.Row="0" Text="Update Album"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="28" FontWeight="Bold"
                               HorizontalAlignment="Center"/>

                    <!-- ComboBox за избор на албум -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                    </Grid>

                    <!-- Форма -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Лява колона -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <!-- Cover picture -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="50*"/>
                                    <ColumnDefinition Width="13*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Cover picture:"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Top" Margin="0,14,0,0"/>
                                <Border Width="72" Height="72"
                                        CornerRadius="8"
                                        Background="{StaticResource AvatarBg}"
                                        ClipToBounds="True" HorizontalAlignment="Left" Margin="116,-10,0,33" Grid.ColumnSpan="3">
                                    <Image x:Name="imageCover" Stretch="UniformToFill"/>
                                </Border>
                                <Button Grid.Column="3" Content="Upload"
                                        Style="{StaticResource SmallBtn}"
                                        Click="buttonUpload_Click"
                                        VerticalAlignment="Top" Margin="15,12,-2,0"/>
                            </Grid>

                            <!-- Album title -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Album title:"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Top" Margin="0,26,0,0"/>
                                <TextBox x:Name="textBoxAlbumTitle" Height="36"
                                         Style="{StaticResource ZenTextBox}" Margin="120,17,10,7" Grid.ColumnSpan="2"/>
                            </Grid>
                        </StackPanel>

                        <!-- Дясна колона -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <!-- Year -->
                            <StackPanel>
                                <TextBlock Text="Release year:"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <TextBox x:Name="textBoxYear"
                                         Height="36"
                                         Style="{StaticResource ZenTextBox}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Бутони -->
                    <StackPanel Grid.Row="6" Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button Content="Cancel" Style="{StaticResource PrimaryBtn}"
                                Width="140" Margin="0,0,16,0" Click="buttonCancel_Click"/>
                        <Button Content="Save" Style="{StaticResource PrimaryBtn}"
                                Width="140" Click="buttonSave_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>