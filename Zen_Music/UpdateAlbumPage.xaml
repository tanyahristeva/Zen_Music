<Window x:Class="Zen_Music.AlbumPages.UpdateAlbumPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Album Page"
        Width="1200" Height="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        
        <!-- ComboBox стил -->
        <Style x:Key="ZenComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#D2D2DC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        
        <!-- TextBox стил -->
        <Style x:Key="ZenTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#D2D2DC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                        Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Основен бутон -->
        <Style x:Key="ZenButton" TargetType="Button">
            <Setter Property="Background" Value="#8EBBFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                        CornerRadius="8" Padding="20,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#6AA3F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4A83D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ZenLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border Background="#1A1D27" CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <!-- Title bar -->
            <Border Height="40" VerticalAlignment="Top" Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseDown" Cursor="SizeAll">
                <TextBlock Text="Update Album Page" Foreground="#7B80A8"
                    FontSize="12" Margin="20,0,0,0" VerticalAlignment="Center"/>
            </Border>

            <Border Margin="40,50,40,40" Background="#22263A" CornerRadius="12">
                <Grid Margin="50,40,50,40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заглавие -->
                    <TextBlock Grid.Row="0" Text="Update Album"
                               FontFamily="Segoe UI" FontSize="45" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"
                               Margin="0,0,0,40"/>

                    <!-- Форма -->
                    <Grid Grid.Row="1" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Лява колона -->
                        <StackPanel Grid.Column="0" Margin="0,5,30,0">
                            <!-- Cover picture -->
                            <Grid Margin="0,0,0,30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Cover picture:" Style="{StaticResource ZenLabel}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Border Width="150" Height="150" Background="#D2D2DC" CornerRadius="8" ClipToBounds="True">
                                        <Image x:Name="imageCover" Stretch="UniformToFill"/>
                                    </Border>
                                    <Button Content="Upload" Style="{StaticResource ZenButton}"
                                            Width="100" Height="40" Margin="50,0,0,60" VerticalAlignment="Bottom"
                                            Click="buttonUpload_Click"/>
                                </StackPanel>
                            </Grid>

                            <!-- Album title -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Album title:" Style="{StaticResource ZenLabel}"/>
                                <TextBox Grid.Column="1" x:Name="textBoxAlbumTitle"
                                         Style="{StaticResource ZenTextBox}" TextChanged="textBoxAlbumTitle_TextChanged_1"/>
                            </Grid>

                            
                        </StackPanel>

                        <!-- Дясна колона -->
                        <StackPanel Grid.Column="1" Margin="30,0,0,0">

                            <!-- Artist name -->
                            <Grid Margin="0,0,0,30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Artist name:" Style="{StaticResource ZenLabel}"/>
                                <ComboBox Grid.Column="1" x:Name="comboBoxArtist" Style="{StaticResource ZenComboBox}"/>
                            </Grid>
                            
                            <!-- Number of songs -->
                            <Grid Margin="0,0,0,30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Number of songs:" Style="{StaticResource ZenLabel}"
                                            TextWrapping="Wrap"/>
                                <TextBox Grid.Column="1" x:Name="textBoxNumberOfSongs" Style="{StaticResource ZenTextBox}"/>
                            </Grid>

                            <!-- Genre -->
                            <Grid Margin="0,0,0,30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Genre:" Style="{StaticResource ZenLabel}"/>
                                <ComboBox Grid.Column="1" x:Name="comboBoxGenre" Style="{StaticResource ZenComboBox}"/>
                            </Grid>

                            <!-- Year -->
                            <Grid Margin="0,0,0,30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Year:" Style="{StaticResource ZenLabel}"/>
                                <TextBox Grid.Column="1" x:Name="textBoxYear" Style="{StaticResource ZenTextBox}"/>
                            </Grid>

                        </StackPanel>
                    </Grid>

                    <!-- Бутони -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,20,0,0">
                        <Button Content="Cancel" Style="{StaticResource ZenButton}"
                                Background="#7B80A8" Width="160" Height="50"
                                Margin="0,0,30,0" Click="buttonCancel_Click"/>
                        <Button Content="Save" Style="{StaticResource ZenButton}"
                                Width="160" Height="50" Click="buttonSave_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>