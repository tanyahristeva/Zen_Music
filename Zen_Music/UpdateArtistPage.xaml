<Window x:Class="Zen_Music.UpdateArtistPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Artist Page"
        Width="720" Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="BgOuter"       Color="#1A1D27"/>
        <SolidColorBrush x:Key="BgPanel"       Color="#22263A"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#8EBBFF"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#EAEAF5"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#7B80A8"/>
        <SolidColorBrush x:Key="InputBg"       Color="#DDDCDC"/>
        <SolidColorBrush x:Key="InputBorder"   Color="#3A3F60"/>
        <SolidColorBrush x:Key="AvatarBg"      Color="#DDDCDC"/>

        <!-- ComboBox стил - без custom template -->
        <Style x:Key="ZenCombo" TargetType="ComboBox">
            <Setter Property="Background"        Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"        Value="#000000"/>
            <Setter Property="BorderBrush"       Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness"   Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="Height"            Value="36"/>
            <Setter Property="Padding"           Value="10,0"/>
            <Setter Property="ItemContainerStyle">


                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground"  Value="#000000"/>
                        <Setter Property="Background"  Value="Transparent"/>
                        <Setter Property="Padding"     Value="10,6"/>
                        <Setter Property="FontSize"    Value="13"/>
                        <Setter Property="Padding" Value="8,0"/>
                        <Setter Property="Height" Value="32"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2E3354"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#343860"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox стил -->
        <Style x:Key="ZenTextBox" TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"      Value="#22263A"/>
            <Setter Property="CaretBrush"      Value="{StaticResource AccentBlue}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">

                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Основен бутон -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground"      Value="#FFF"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="22" Padding="32,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#82BEFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5495D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="16" Padding="18,7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#82BEFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgOuter}" CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <!-- Title bar -->
            <Border Height="36" VerticalAlignment="Top" Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseDown" Cursor="SizeAll">
                <TextBlock Text="Update Artist Page" Foreground="{StaticResource TextSecondary}"
                           FontSize="11" Margin="16,0,0,0" VerticalAlignment="Center"/>
            </Border>

            <Border Margin="20,36,20,20" Background="{StaticResource BgPanel}" CornerRadius="12">
                <Grid Margin="40,24,40,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заглавие -->
                    <TextBlock Grid.Row="0" Text="Update Artist"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="28" FontWeight="Bold"
                               HorizontalAlignment="Center"/>

                    <!-- ComboBox за избор на артист -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                    </Grid>

                    <!-- Форма -->
                    <Grid Margin="0,10,0,0" Grid.RowSpan="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="247*"/>
                            <ColumnDefinition Width="38*"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="284*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Лява колона -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Grid.ColumnSpan="2">
                            <!-- Profile picture -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Profile picture:"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border Width="72" Height="72"
                                        CornerRadius="36" Background="{StaticResource AvatarBg}"
                                        ClipToBounds="True" HorizontalAlignment="Left"
                                        Grid.ColumnSpan="2" Margin="121,10,0,13">
                                    <Image x:Name="imageArtist" Stretch="UniformToFill" Margin="0,-53,0,53"/>
                                </Border>
                                <Button Grid.Column="2" Content="Upload"
                                        Style="{StaticResource SmallBtn}"
                                        Click="buttonUpload_Click"
                                        VerticalAlignment="Top" Margin="13,30,0,0"/>
                            </Grid>

                            <!-- Artist name -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Artist name:"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Top" Margin="0,33,0,0"/>
                                <TextBox x:Name="textBoxArtistName"
                                         Grid.Column="1" Height="36"
                                         Style="{StaticResource ZenTextBox}" Margin="0,17,0,7"/>
                            </Grid>
                        </StackPanel>

                        <!-- Дясна колона -->
                        <StackPanel Grid.Column="3" VerticalAlignment="Center">
                            <!-- Description -->
                            <StackPanel>
                                <TextBlock Text="Description:"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="14" FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <TextBox x:Name="textBoxDescription"
                                         Height="110"
                                         Style="{StaticResource ZenTextBox}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalContentAlignment="Top"
                                         Padding="10,8"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Бутони -->
                    <StackPanel Grid.Row="6" Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button Content="Cancel" Style="{StaticResource PrimaryBtn}"
                                Width="140" Margin="0,0,16,0" Click="buttonCancel_Click"/>
                        <Button Content="Save" Style="{StaticResource PrimaryBtn}"
                                Width="140" Click="buttonSave_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>