<Window x:Class="Zen_Music.AlbumPages.UpdateAlbumSearchPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Album Search Page"
        Width="720" Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="BgOuter"       Color="#1A1D27"/>
        <SolidColorBrush x:Key="BgPanel"       Color="#22263A"/>
        <SolidColorBrush x:Key="BgList"        Color="#1C1F2E"/>
        <SolidColorBrush x:Key="BgRow"         Color="#252840"/>
        <SolidColorBrush x:Key="BgRowHover"    Color="#2E3354"/>
        <SolidColorBrush x:Key="BgRowSelected" Color="#343860"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#8EBBFF"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#EAEAF5"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#7B80A8"/>
        <SolidColorBrush x:Key="TextItalic"    Color="#5C6180"/>
        <SolidColorBrush x:Key="BorderColor"   Color="#2F3350"/>
        <SolidColorBrush x:Key="SearchBg"      Color="#DDDCDC"/>
        <SolidColorBrush x:Key="AvatarBg"      Color="#3A3F60"/>

        <!-- Slim ScrollBar -->
        <Style x:Key="SlimScrollBar" TargetType="ScrollBar">
            <Setter Property="Width"      Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="3" Background="#3D4270" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SlimScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1"
                                       Style="{StaticResource SlimScrollBar}"
                                       Orientation="Vertical"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ListViewItem стил -->
        <Style x:Key="AlbumRowStyle" TargetType="ListViewItem">
            <Setter Property="Background"   Value="{StaticResource BgRow}"/>
            <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="0,2,0,0">
                            <ContentPresenter Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgRowHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgRowSelected}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Основен бутон -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground"      Value="#FFF"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="22" Padding="32,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#82BEFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5495D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Update икона бутон -->
        <Style x:Key="UpdateIcon" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="17" Width="34" Height="34">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A3A5A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgOuter}" CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <!-- Title bar -->
            <Border Height="36" VerticalAlignment="Top" Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseDown" Cursor="SizeAll">
                <TextBlock Text="Update Album Search Page" Foreground="{StaticResource TextSecondary}"
                           FontSize="11" Margin="16,0,0,0" VerticalAlignment="Center"/>
            </Border>

            <Border Margin="20,36,20,20" Background="{StaticResource BgPanel}" CornerRadius="12">
                <Grid Margin="30,28,30,28">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заглавие -->
                    <TextBlock Grid.Row="0" Text="Update Album"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="28" FontWeight="Bold"
                               HorizontalAlignment="Center"/>

                    <!-- Search bar -->
                    <Border Grid.Row="2" Background="{StaticResource BgList}"
                            CornerRadius="10" Padding="12,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Please search for an album to update"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="13" VerticalAlignment="Center"
                                       Margin="0,0,16,0"/>
                            <TextBox x:Name="textBoxSearch"
                                     Grid.Column="1" Width="200" Height="34"
                                     Background="{StaticResource SearchBg}"
                                     Foreground="#22263A"
                                     CaretBrush="{StaticResource AccentBlue}"
                                     BorderBrush="{StaticResource BorderColor}"
                                     BorderThickness="1"
                                     Padding="10,0" FontSize="13"
                                     VerticalContentAlignment="Center"
                                     TextChanged="textBoxSearch_TextChanged">
                                <TextBox.Template>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Margin="{TemplateBinding Padding}"
                                                          VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </TextBox.Template>
                            </TextBox>
                            <Border Grid.Column="2" Width="34" Height="34"
                                    Background="{StaticResource SearchBg}"
                                    BorderBrush="{StaticResource BorderColor}"
                                    BorderThickness="1" CornerRadius="8" Margin="4,0,0,0">
                                <TextBlock Text="🔍" FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Album list -->
                    <Border Grid.Row="4" Background="{StaticResource BgList}"
                            CornerRadius="10" ClipToBounds="True">
                        <ListView x:Name="listViewAlbums"
                                  Background="Transparent" BorderThickness="0"
                                  ItemContainerStyle="{StaticResource AlbumRowStyle}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  Padding="6" SelectionMode="Single">
                            <ListView.Resources>
                                <Style TargetType="ScrollViewer" BasedOn="{StaticResource SlimScrollViewer}"/>
                            </ListView.Resources>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="64" Margin="4,0,4,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="36"/>
                                            <ColumnDefinition Width="58"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="38"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- # -->
                                        <TextBlock Grid.Column="0" Text="{Binding RowIndex}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="13" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                        <!-- Корица -->
                                        <Border Grid.Column="1" Width="46" Height="46"
                                                CornerRadius="6"
                                                Background="{StaticResource AvatarBg}"
                                                ClipToBounds="True" VerticalAlignment="Center">
                                            <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                                        </Border>

                                        <!-- Заглавие + Артист -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                                    Margin="12,0,8,0">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Artist}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Година -->
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Year}"
                                                   Foreground="{StaticResource TextItalic}"
                                                   FontStyle="Italic" FontSize="13"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Left"/>

                                        <!-- Update бутон -->
                                        <Button Grid.Column="4"
                                                Style="{StaticResource UpdateIcon}"
                                                Tag="{Binding AlbumId}"
                                                Click="UpdateRow_Click"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                            <Path Data="M4,12 A8,8 0 1 1 8,19.5 M4,12 L4,8 M4,12 L8,12"
                                                  Stroke="{StaticResource AccentBlue}"
                                                  StrokeThickness="1.8"
                                                  StrokeLineJoin="Round"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Width="16" Height="16" Stretch="Uniform"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>

                    <!-- Бутони -->
                    <StackPanel Grid.Row="6" Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button Content="Cancel" Style="{StaticResource PrimaryBtn}"
                                Width="150" Margin="0,0,16,0" Click="buttonCancel_Click"/>
                        <Button Content="Update Selected" Style="{StaticResource PrimaryBtn}"
                                Width="150" Click="buttonUpdate_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>