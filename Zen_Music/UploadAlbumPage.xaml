<Window x:Class="Zen_Music.AlbumPages.UploadAlbumPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upload Album Page"
        Width="720" Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="BgOuter"       Color="#1A1D27"/>
        <SolidColorBrush x:Key="BgPanel"       Color="#22263A"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#8EBBFF"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#EAEAF5"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#7B80A8"/>
        <SolidColorBrush x:Key="InputBg"       Color="#D2D2DC"/>
        <SolidColorBrush x:Key="InputBorder"   Color="#3A3F60"/>
        <SolidColorBrush x:Key="CoverBg"       Color="#D2D2DC"/>

        <!-- TextBox -->
        <Style x:Key="ZenTextBox" TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"      Value="#22263A"/>
            <Setter Property="CaretBrush"      Value="{StaticResource AccentBlue}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox - без custom template -->
        <Style x:Key="ZenCombo" TargetType="ComboBox">
            <Setter Property="Background"      Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"      Value="#000000"/>
            <Setter Property="BorderBrush"     Value="{StaticResource InputBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#000000"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding"    Value="10,6"/>
                        <Setter Property="FontSize"   Value="13"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2E3354"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#343860"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Основен бутон -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground"      Value="#FFF"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="22" Padding="32,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#82BEFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5495D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Малък бутон -->
        <Style x:Key="SmallBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="16" Padding="18,7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#82BEFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5495D4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgOuter}" CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <!-- Title bar -->
            <Border Height="36" VerticalAlignment="Top" Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseDown" Cursor="SizeAll">
                <TextBlock Text="Upload Album Page" Foreground="{StaticResource TextSecondary}"
                           FontSize="11" Margin="16,0,0,0" VerticalAlignment="Center"/>
            </Border>

            <Border Margin="20,36,20,20" Background="{StaticResource BgPanel}" CornerRadius="12">
                <Grid Margin="40,24,40,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заглавие -->
                    <TextBlock Grid.Row="0" Text="Upload Album"
                               Foreground="{StaticResource TextPrimary}"
                               FontSize="28" FontWeight="Bold"
                               HorizontalAlignment="Center"/>

                    <!-- Форма: две колони -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ══ ЛЯВА КОЛОНА ══ -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">

                            <!-- Cover picture -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Cover picture:"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Top" Margin="0,-15,0,0"/>
                                <Border Width="64" Height="64"
                                        CornerRadius="8"
                                        Background="{StaticResource CoverBg}"
                                        ClipToBounds="True"
                                        HorizontalAlignment="Left" Grid.ColumnSpan="2" Margin="109,-38,0,38">
                                    <Image x:Name="imageCover" Stretch="UniformToFill" Margin="0,-1,0,1"/>
                                </Border>
                                <Button Grid.Column="2" Content="Upload"
                                        Style="{StaticResource SmallBtn}"
                                        VerticalAlignment="Top" Margin="10,-21,0,0"
                                        Click="buttonUpload_Click"/>
                            </Grid>

                            <!-- Album name -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Album name:"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="textBoxAlbumName"
                                         Grid.Column="1"
                                         Style="{StaticResource ZenTextBox}"/>
                            </Grid>

                            <!-- Artist name (ComboBox) -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Artist name:"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <ComboBox x:Name="comboBoxArtist"
                                          Grid.Column="1"
                                          Style="{StaticResource ZenCombo}"/>
                            </Grid>

                        </StackPanel>

                        <!-- ══ ДЯСНА КОЛОНА ══ -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">

                            <!-- Add file -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Add file:"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1" x:Name="buttonSelectFile"
                                        Content="Select file"
                                        Style="{StaticResource SmallBtn}"
                                        HorizontalAlignment="Left"
                                        Click="buttonSelectFile_Click"/>
                            </Grid>

                            <!-- Number of songs -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Number of songs:"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                                <TextBox x:Name="textBoxNumberOfSongs"
                                         Grid.Column="1"
                                         Style="{StaticResource ZenTextBox}"/>
                            </Grid>

                            <!-- Genre (ComboBox) -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Genre:"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="14" FontWeight="SemiBold"
                                           
                                           VerticalAlignment="Center"/>
                                <ComboBox x:Name="comboBoxGenre"
                                          Grid.Column="1"
                                          Style="{StaticResource ZenCombo}"/>
                            </Grid>

                            <!-- Year -->
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Year:"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="14" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBox x:Name="textBoxYear"
                                         Grid.Column="1"
                                         Style="{StaticResource ZenTextBox}"/>
                            </Grid>

                        </StackPanel>
                    </Grid>

                    <!-- Бутони -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button Content="Cancel" Style="{StaticResource PrimaryBtn}"
                                Width="140" Margin="0,0,16,0" Click="buttonCancel_Click"/>
                        <Button Content="Save" Style="{StaticResource PrimaryBtn}"
                                Width="140" Click="buttonSave_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>