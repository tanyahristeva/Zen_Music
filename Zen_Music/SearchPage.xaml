<Window x:Class="Zen_Music.SearchPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Search Page"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        KeyDown="Window_KeyDown"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="BgMain"        Color="#1A1D2E"/>
        <SolidColorBrush x:Key="BgNav"         Color="#12141F"/>
        <SolidColorBrush x:Key="BgPanel"       Color="#22263A"/>
        <SolidColorBrush x:Key="BgRow"         Color="#1C1F2E"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#8EBBFF"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#EAEAF5"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#7B80A8"/>
        <SolidColorBrush x:Key="PlayerBg"      Color="#12141F"/>

        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2E45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterBtn" TargetType="Button">
            <Setter Property="Background"      Value="#2A2E45"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Padding"         Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3F60"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2E45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SlimScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="2" Background="#3D4270" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SlimScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1"
                                       Style="{StaticResource SlimScrollBar}"
                                       Orientation="Vertical"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SongRowStyle" TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Margin="0,2,0,0">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2E45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgMain}" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="90"/>
            </Grid.RowDefinitions>

            <!-- NAV -->
            <Border Grid.Row="0" Height="64" Background="{StaticResource BgNav}" CornerRadius="12,12,0,0">
                <Grid Margin="16,0,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="ZEN"
                               Foreground="{StaticResource AccentBlue}"
                               FontSize="18" FontWeight="Bold"
                               VerticalAlignment="Center"
                               MouseLeftButtonDown="txtZen_Click" Cursor="Hand"/>
                    <Border Grid.Column="1" Background="#DDDCDC" CornerRadius="16"
                            Height="36" Width="340" HorizontalAlignment="Center">
                        <Grid Margin="10,0,8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtSearch"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#22263A"
                                     CaretBrush="{StaticResource AccentBlue}"
                                     FontSize="12" VerticalContentAlignment="Center"
                                     KeyDown="txtSearch_KeyDown"/>
                            <Button Grid.Column="1" Style="{StaticResource NavBtn}"
                                    Padding="0" Click="btnSearch_Click">
                                <TextBlock Text="🔍" FontSize="12"
                                           Foreground="{StaticResource TextSecondary}"/>
                            </Button>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource NavBtn}">
                            <TextBlock Text="🗄" FontSize="20" Foreground="{StaticResource TextSecondary}"/>
                        </Button>
                        <Button Style="{StaticResource NavBtn}">
                            <TextBlock Text="👥" FontSize="20" Foreground="{StaticResource TextSecondary}"/>
                        </Button>
                        <Button Style="{StaticResource NavBtn}" Click="btnProfile_Click">
                            <TextBlock Text="👤" FontSize="20" Foreground="{StaticResource TextSecondary}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CONTENT -->
            <Grid Grid.Row="1" Margin="16,12,16,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Results label + filter toggle -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="txtResultsLabel"
                                       Text="Results for ''"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="26" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="btnToggleFilters"
                                    Style="{StaticResource FilterBtn}"
                                    Content="⚙ Filters"
                                    FontSize="15"
                                    Padding="16,8"
                                    Click="btnToggleFilters_Click"/>     
                </Grid>

                <!-- Filters panel -->
                <Border x:Name="filtersPanel" Grid.Row="1" Background="{StaticResource BgPanel}"
                            CornerRadius="10" Padding="12,10" Margin="0,0,0,10"
                            Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Genre -->
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Foreground="{StaticResource AccentBlue}"
                                       FontSize="16" FontWeight="Bold"
                                       Margin="0,0,0,6">
                                <Run Text="🎵"/> <Run Text="Genre"/>
                            </TextBlock>
                            <WrapPanel>
                                <Button Content="All" Tag="All" Style="{StaticResource FilterBtn}"
                                        Margin="0,0,6,6" Click="btnGenre_Click"/>
                                <Button Content="Pop" Tag="Pop" Style="{StaticResource FilterBtn}"
                                        Margin="0,0,6,6" Click="btnGenre_Click"/>
                                <Button Content="Rock" Tag="Rock" Style="{StaticResource FilterBtn}"
                                        Margin="0,0,6,6" Click="btnGenre_Click"/>
                                <Button Content="Hip Hop" Tag="Hip Hop" Style="{StaticResource FilterBtn}"
                                        Margin="0,0,6,6" Click="btnGenre_Click"/>
                                <Button Content="Indie" Tag="Indie" Style="{StaticResource FilterBtn}"
                                        Margin="0,0,6,6" Click="btnGenre_Click"/>
                                <Button Content="Jazz" Tag="Jazz" Style="{StaticResource FilterBtn}"
                                        Margin="0,0,6,6" Click="btnGenre_Click"/>
                            </WrapPanel>
                        </StackPanel>

                        <!-- Year/Decade -->
                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Foreground="{StaticResource AccentBlue}"
                                       FontSize="16" FontWeight="Bold"
                                       Margin="0,0,0,6">
                                <Run Text="📅"/> <Run Text="Year"/>
                            </TextBlock>
                            <WrapPanel>
                                <Button Content="2020s" Tag="2020s" Style="{StaticResource FilterBtn}"
                                        Margin="0,0,6,6" Click="btnDecade_Click"/>
                                <Button Content="2010s" Tag="2010s" Style="{StaticResource FilterBtn}"
                                        Margin="0,0,6,6" Click="btnDecade_Click"/>
                                <Button Content="2000s" Tag="2000s" Style="{StaticResource FilterBtn}"
                                        Margin="0,0,6,6" Click="btnDecade_Click"/>
                                <Button Content="1990s" Tag="1990s" Style="{StaticResource FilterBtn}"
                                        Margin="0,0,6,6" Click="btnDecade_Click"/>
                                <Button Content="1980s" Tag="1980s" Style="{StaticResource FilterBtn}"
                                        Margin="0,0,6,6" Click="btnDecade_Click"/>
                            </WrapPanel>
                        </StackPanel>

                        <!-- Duration -->
                        <StackPanel Grid.Column="2" Margin="0,0,8,0">
                            <TextBlock Foreground="{StaticResource AccentBlue}"
                                       FontSize="16" FontWeight="Bold"
                                       Margin="0,0,0,6">
                                <Run Text="⏱"/> <Run Text="Length"/>
                            </TextBlock>
                            <TextBlock Foreground="{StaticResource TextSecondary}"
                                       FontSize="14" Margin="0,0,0,4">
                                <Run Text="Min: "/>
                                <Run x:Name="txtMinDur" Text="0:00"/>
                            </TextBlock>
                            <Slider x:Name="sliderMinDur" Minimum="0" Maximum="600" Value="0"
                                    Foreground="{StaticResource AccentBlue}"
                                    ValueChanged="sliderDuration_ValueChanged"
                                    Margin="0,0,0,4"/>
                            <TextBlock Foreground="{StaticResource TextSecondary}"
                                       FontSize="14" Margin="0,0,0,4">
                                <Run Text="Max: "/>
                                <Run x:Name="txtMaxDur" Text="10:00"/>
                            </TextBlock>
                            <Slider x:Name="sliderMaxDur" Minimum="0" Maximum="600" Value="600"
                                    Foreground="{StaticResource AccentBlue}"
                                    ValueChanged="sliderDuration_ValueChanged"/>
                        </StackPanel>

                        <!-- Preferences -->
                        <StackPanel Grid.Column="3">
                            <TextBlock Foreground="{StaticResource AccentBlue}"
                                       FontSize="16" FontWeight="Bold"
                                       Margin="0,0,0,10">
                                <Run Text="⚙"/> <Run Text="Preferences"/>
                            </TextBlock>

                            <!-- Liked -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="⭐ Liked"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="15" VerticalAlignment="Center"/>   
                                <Border Grid.Column="1" x:Name="toggleLikedBorder"
                                        Width="46" Height="24" CornerRadius="12"
                                        Background="#2A2E45" Cursor="Hand"
                                        MouseLeftButtonDown="toggleLiked_Click">
                                    <Ellipse x:Name="toggleLikedDot"
                                             Width="18" Height="18"
                                             Fill="{StaticResource TextSecondary}"
                                             HorizontalAlignment="Left"
                                             Margin="3,0,0,0"/>
                                </Border>
                            </Grid>

                            <!-- Downloaded -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="⬇ Downloaded"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="15" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" x:Name="toggleDownloadedBorder"
                                        Width="46" Height="24" CornerRadius="12"
                                        Background="#2A2E45" Cursor="Hand"
                                        MouseLeftButtonDown="toggleDownloaded_Click">
                                    <Ellipse x:Name="toggleDownloadedDot"
                                             Width="18" Height="18"
                                             Fill="{StaticResource TextSecondary}"
                                             HorizontalAlignment="Left"
                                             Margin="3,0,0,0"/>
                                </Border>
                            </Grid>

                            <!-- Explicit -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔞 Explicit"
                                           Foreground="{StaticResource TextPrimary}"
                                           FontSize="15" VerticalAlignment="Center"/>
                                <Border Grid.Column="1" x:Name="toggleExplicitBorder"
                                        Width="46" Height="24" CornerRadius="12"
                                        Background="#2A2E45" Cursor="Hand"
                                        MouseLeftButtonDown="toggleExplicit_Click">
                                    <Ellipse x:Name="toggleExplicitDot"
                                             Width="18" Height="18"
                                             Fill="{StaticResource TextSecondary}"
                                             HorizontalAlignment="Left"
                                             Margin="3,0,0,0"/>
                                </Border>
                            </Grid>

                            <Button Content="Search" Style="{StaticResource FilterBtn}"
                                    Background="{StaticResource AccentBlue}"
                                    Foreground="White" HorizontalAlignment="Right"
                                    FontSize="15" Padding="20,8"
                                    Margin="0,4,0,0" Click="btnApplyFilters_Click"/>
                        </StackPanel>


                    </Grid>
                </Border>



                <!-- Results -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Songs -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Songs"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="20" FontWeight="Bold"
                                   Margin="0,0,0,10"/>
                        <ListView Grid.Row="1" x:Name="listSongs"
                                  Background="Transparent" BorderThickness="0"
                                  ItemContainerStyle="{StaticResource SongRowStyle}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">    
                            <ListView.Resources>
                                <Style TargetType="ScrollViewer" BasedOn="{StaticResource SlimScrollViewer}"/>
                            </ListView.Resources>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="72" Margin="4,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Cover -->
                                        <Border Grid.Column="0" Width="54" Height="54"
                                CornerRadius="10" Background="#2A2E45"
                                ClipToBounds="True" VerticalAlignment="Center">
                                            <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                                        </Border>

                                        <!-- Title + Artist -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                    Margin="12,0,8,0">
                                            <TextBlock Text="{Binding Title}"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="15" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Artist}"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="13"
                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Duration -->
                                        <TextBlock Grid.Column="2"
                                   Text="{Binding Duration}"
                                   Foreground="{StaticResource TextSecondary}"
                                   FontSize="13" VerticalAlignment="Center"
                                   Margin="0,0,12,0"/>

                                        <!-- Like -->
                                        <Button Grid.Column="3" Style="{StaticResource IconBtn}"
                                Tag="{Binding SongId}"
                                Click="LikeSong_Click" Padding="8">
                                            <TextBlock FontSize="18"
                                       Foreground="{StaticResource AccentBlue}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="☆"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLiked}" Value="True">
                                                                <Setter Property="Text" Value="★"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>

                                        <!-- Download -->
                                        <Button Grid.Column="4" Style="{StaticResource IconBtn}"
                                Tag="{Binding SongId}"
                                Click="DownloadSong_Click" Padding="8">
                                            <TextBlock Text="⬇" FontSize="18"
                                       Foreground="{StaticResource TextSecondary}"/>
                                        </Button>

                                        <!-- More options -->
                                        <Button Grid.Column="5" Style="{StaticResource IconBtn}"
                                Padding="8">
                                            <TextBlock Text="⋮" FontSize="20"
                                       Foreground="{StaticResource TextSecondary}"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <!-- Playlists -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Playlists"
                   Foreground="{StaticResource TextPrimary}"
                   FontSize="20" FontWeight="Bold"
                   Margin="0,0,0,10"/>
                        <ListView Grid.Row="1" x:Name="listPlaylists"
                  Background="Transparent" BorderThickness="0"
                  ItemContainerStyle="{StaticResource SongRowStyle}"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.Resources>
                                <Style TargetType="ScrollViewer" BasedOn="{StaticResource SlimScrollViewer}"/>
                            </ListView.Resources>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="72" Margin="4,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Cover -->
                                        <Border Grid.Column="0" Width="54" Height="54"
                                CornerRadius="6" Background="#2A2E45"
                                ClipToBounds="True" VerticalAlignment="Center">
                                            <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                                        </Border>

                                        <!-- Name + Creator -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                    Margin="12,0,8,0">
                                            <TextBlock Text="{Binding Name}"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="15" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Creator}"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="13"
                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- Like -->
                                        <Button Grid.Column="2" Style="{StaticResource IconBtn}"
                                Padding="8">
                                            <TextBlock Text="☆" FontSize="18"
                                       Foreground="{StaticResource AccentBlue}"/>
                                        </Button>

                                        <!-- Download -->
                                        <Button Grid.Column="3" Style="{StaticResource IconBtn}"
                                Padding="8">
                                            <TextBlock Text="⬇" FontSize="18"
                                       Foreground="{StaticResource TextSecondary}"/>
                                        </Button>

                                        <!-- More options -->
                                        <Button Grid.Column="4" Style="{StaticResource IconBtn}"
                                Padding="8">
                                            <TextBlock Text="⋮" FontSize="20"
                                       Foreground="{StaticResource TextSecondary}"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>

            </Grid>


            <!-- PLAYER BAR -->
            <Border Grid.Row="2" Height="90" Background="{StaticResource PlayerBg}" CornerRadius="0,0,12,12">
                <Grid Margin="20,0,20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <!-- Song info -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="60" Height="60" CornerRadius="6"
                    Background="#22263A" Margin="0,0,12,0">
                            <TextBlock Text="♪" FontSize="26"
                           Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="No song playing"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="---"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="13"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Controls -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,-12,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,0,0,2">
                            <Button Style="{StaticResource NavBtn}">
                                <TextBlock Text="⇄" FontSize="20" Foreground="{StaticResource TextSecondary}"/>
                            </Button>
                            <Button Style="{StaticResource NavBtn}">
                                <TextBlock Text="⏮" FontSize="20" Foreground="{StaticResource TextSecondary}"/>
                            </Button>
                            <Button Style="{StaticResource NavBtn}">
                                <TextBlock Text="⏸" FontSize="26" Foreground="{StaticResource TextPrimary}"/>
                            </Button>
                            <Button Style="{StaticResource NavBtn}">
                                <TextBlock Text="⏭" FontSize="20" Foreground="{StaticResource TextSecondary}"/>
                            </Button>
                            <Button Style="{StaticResource NavBtn}">
                                <TextBlock Text="↺" FontSize="20" Foreground="{StaticResource TextSecondary}"/>
                            </Button>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="0:00"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="12" HorizontalAlignment="Right"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <Border Grid.Column="1" Height="4" CornerRadius="2"
                        Background="#2A2E45" VerticalAlignment="Center">
                                <Border Width="0" Height="4" CornerRadius="2"
                            Background="{StaticResource AccentBlue}"
                            HorizontalAlignment="Left"/>
                            </Border>
                            <TextBlock Grid.Column="2" Text="0:00"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="12" HorizontalAlignment="Left"
                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </Grid>
                    </StackPanel>

                    <!-- Volume -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                    VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Text="🔊" FontSize="20"
                       Foreground="{StaticResource TextSecondary}"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Border Height="4" Width="120" CornerRadius="2"
                    Background="#2A2E45" VerticalAlignment="Center">
                            <Border Width="70" Height="4" CornerRadius="2"
                        Background="{StaticResource AccentBlue}"
                        HorizontalAlignment="Left"/>
