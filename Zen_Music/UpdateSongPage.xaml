<Window x:Class="Zen_Music.UpdateSongPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Song Page - ZEN Music"
        
        Width="1200" Height="700"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="ZenButton" TargetType="Button">
            <Setter Property="Background" Value="#8EBBFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="20,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#6AA3F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4A83D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ZenLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ZenTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#D2D2DC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ZenComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#D2D2DC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

        </Style>
    </Window.Resources>



    <Border Background="#1A1D27" CornerRadius="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
        </Border.Effect>

        <!-- Title bar -->
        <Grid>
            <Border Height="40" VerticalAlignment="Top" Background="Transparent"
                    MouseLeftButtonDown="TitleBar_MouseDown" Cursor="SizeAll">
                <TextBlock Text="Update Song Page" Foreground="#7B80A8"
           FontSize="12" Margin="20,0,0,0" VerticalAlignment="Center"/>
            </Border>

            <Border Margin="40,50,40,40" Background="#22263A" CornerRadius="12">

                <Grid Margin="50,40,50,40">
        <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Grid.Row="0" Text="Update Song"
                FontFamily="Segoe UI" FontSize="45" FontWeight="Bold"
                Foreground="White" HorizontalAlignment="Center"
                Margin="0,0,0,40"/>

        <!-- CONTENT -->
            <Grid Grid.Row="1" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

            <!-- LEFT -->
            <StackPanel Grid.Column="0" Margin="0,20,30,0">

                <!-- Cover picture -->
                <Grid Margin="0,0,0,40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Cover picture:" Style="{StaticResource ZenLabel}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Border Width="120" Height="120" Background="#D2D2DC"
                                CornerRadius="8" ClipToBounds="True">
                            <Image x:Name="imgCover" Stretch="UniformToFill"/>
                        </Border>
                        <Button x:Name="btnUpload" Content="Upload"
                    Style="{StaticResource ZenButton}"
                    Width="100" Height="40"
                    Margin="50,0,0,40" VerticalAlignment="Bottom"
                    Click="btnUpload_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Song name -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Song name:" Style="{StaticResource ZenLabel}"/>
                    <TextBox Grid.Column="1" x:Name="txtSongName" Style="{StaticResource ZenTextBox}"/>
                </Grid>

                <!-- Artist name -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Artist name:" Style="{StaticResource ZenLabel}"/>
                    <ComboBox Grid.Column="1" x:Name="cmbArtist" Style="{StaticResource ZenComboBox}"
                              DisplayMemberPath="Name" SelectedValuePath="ID"/>
                </Grid>

            </StackPanel>

            <!-- RIGHT -->
            <StackPanel Grid.Column="1" Margin="30,0,0,0">

                <!-- Add file -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Add file:" Style="{StaticResource ZenLabel}"/>
                    <StackPanel Grid.Column="1">
                        <Button x:Name="btnSelectFile" Content="Select file"
                                Style="{StaticResource ZenButton}"
                                Width="120" Height="40" HorizontalAlignment="Left"
                                Click="btnSelectFile_Click"/>
                        <TextBlock x:Name="lblFileName" Text="No file selected"
                                   Foreground="#BBBBBB" FontFamily="Segoe UI" FontSize="12"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Duration -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Duration:" Style="{StaticResource ZenLabel}"/>
                    <TextBox Grid.Column="1" x:Name="txtDuration" Style="{StaticResource ZenTextBox}"
                             ToolTip="Format: mm:ss (e.g. 3:41)"/>
                </Grid>

                <!-- Genre -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Genre:" Style="{StaticResource ZenLabel}"/>
                    <ComboBox Grid.Column="1" x:Name="cmbGenre" Style="{StaticResource ZenComboBox}"
                              DisplayMemberPath="Name" SelectedValuePath="ID"/>
                </Grid>

                <!-- Album -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Album:" Style="{StaticResource ZenLabel}"/>
                    <ComboBox Grid.Column="1" x:Name="cmbAlbum" Style="{StaticResource ZenComboBox}"
                              DisplayMemberPath="Title" SelectedValuePath="ID"/>
                </Grid>

                <!-- Year (read-only) -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Year:" Style="{StaticResource ZenLabel}"/>
                    <TextBox Grid.Column="1" x:Name="txtYear" Style="{StaticResource ZenTextBox}"
                             IsReadOnly="True" Background="#B8B8C8"/>
                </Grid>

            </StackPanel>
        </Grid>

        <!-- BUTTONS -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,20,0,0"> 
                <Button x:Name="btnCancel" Content="Cancel"
                    Style="{StaticResource ZenButton}"
                    Background="#7B80A8"
                    Width="160" Height="50" Margin="0,0,30,0"
                    Click="btnCancel_Click"/>
                <Button x:Name="btnSave" Content="Save"
                    Style="{StaticResource ZenButton}"
                    Width="160" Height="50"
                    Click="btnSave_Click"/>
            </StackPanel>
                
                </Grid>
            </Border>
        </Grid>
    </Border>
    
</Window>
