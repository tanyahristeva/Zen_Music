<Window x:Class="Zen_Music.HomePageMain"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Home Page Main"
        Width="1200" Height="750"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        KeyDown="Window_KeyDown"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="BgMain"        Color="#1A1D2E"/>
        <SolidColorBrush x:Key="BgNav"         Color="#12141F"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#8EBBFF"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#EAEAF5"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#7B80A8"/>
        <SolidColorBrush x:Key="CardBg"        Color="#22263A"/>
        <SolidColorBrush x:Key="PlayerBg"      Color="#12141F"/>

        <!-- Nav бутон -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2E45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Arrow бутон за Events -->
        <Style x:Key="ArrowBtn" TargetType="Button">
            <Setter Property="Background"      Value="#2A2E45"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slim ScrollBar хоризонтален -->
        <Style x:Key="SlimScrollBar" TargetType="ScrollBar">
            <Setter Property="Height"    Value="3"/>
            <Setter Property="MinHeight" Value="3"/>
            <Setter Property="MaxHeight" Value="3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="1" Background="#4A4F7A" Margin="0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slim ScrollBar -->
        <Style x:Key="SlimScrollBarV" TargetType="ScrollBar">
            <Setter Property="Width"    Value="3"/>
            <Setter Property="MinWidth" Value="3"/>
            <Setter Property="MaxWidth" Value="3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="1" Background="#4A4F7A" Margin="0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SlimScrollViewerV" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1"
                               Style="{StaticResource SlimScrollBarV}"
                               Orientation="Vertical"
                               Value="{TemplateBinding VerticalOffset}"
                               Maximum="{TemplateBinding ScrollableHeight}"
                               ViewportSize="{TemplateBinding ViewportHeight}"
                               Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HorizScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Row="0"/>
                            <ScrollBar Grid.Row="1"
                                       Style="{StaticResource SlimScrollBar}"
                                       Orientation="Horizontal"
                                       Value="{TemplateBinding HorizontalOffset}"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgMain}" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── NAV BAR ── -->
            <Border x:Name="HeaderPanel" Height="64" Grid.Row="0" Background="{StaticResource BgNav}" CornerRadius="12,12,0,0">
                <Grid Margin="16,0,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <TextBlock Grid.Column="0" Text="ZEN"
                               Foreground="{StaticResource AccentBlue}"
                               FontSize="18" FontWeight="Bold"
                               VerticalAlignment="Center"
                               />

                    <!-- Search -->
                    <Border Grid.Column="1" Background="#DDDCDC" CornerRadius="16"
                            Height="36" Width="340" HorizontalAlignment="Center">
                        <Grid Margin="10,0,8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Background="Transparent" BorderThickness="0"
                                     KeyDown="txtSearch_KeyDown"
                                     Foreground="#22263A"
                                     FontSize="12" VerticalContentAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="🔍" FontSize="14"
                                       Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center"/>

                        </Grid>
                    </Border>

                    <!-- Icons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <!-- button maximize here -->
                        <Button Style="{StaticResource NavBtn}">
                            <TextBlock Text="🗄" FontSize="20" Foreground="{StaticResource TextSecondary}"/>
                        </Button>
                        <Button Style="{StaticResource NavBtn}">
                            <TextBlock Text="👥" FontSize="20" Foreground="{StaticResource TextSecondary}"/>
                        </Button>

                        <Button Style="{StaticResource NavBtn}" Click="btnProfile_Click">
                            <TextBlock Text="👤" FontSize="20" Foreground="{StaticResource TextSecondary}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── CONTENT ── -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="380"/>
                </Grid.ColumnDefinitions>

                <!-- Лява: For You + Trending -->
                <ScrollViewer Grid.Column="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Style="{StaticResource SlimScrollViewerV}"
                              Margin="16,12,8,8"
                              PreviewMouseWheel="LeftPanel_PreviewMouseWheel">
                    <StackPanel>

                        <!-- For You -->
                        <TextBlock Text="For You"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="20" FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Hidden"
                                      Style="{StaticResource HorizScrollViewer}">
                            <ItemsControl x:Name="listForYou">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Width="130" Margin="0,0,16,8" Cursor="Hand">
                                            <Border Width="120" Height="120" CornerRadius="8"
                                                    Background="{StaticResource CardBg}"
                                                    ClipToBounds="True">
                                                <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                                            </Border>
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding Artist}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Trending -->
                        <TextBlock Text="Trending"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="20" FontWeight="Bold"
                                   Margin="0,12,0,10"/>

                        <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"
                                      Style="{StaticResource HorizScrollViewer}">
                            <ItemsControl x:Name="listTrending">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Width="130" Margin="0,0,16,8" Cursor="Hand">
                                            <Border Width="120" Height="120" CornerRadius="8"
                                                    Background="{StaticResource CardBg}"
                                                    ClipToBounds="True">
                                                <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                                            </Border>
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding Artist}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>


                        <!-- Personalized Playlists -->
                        <TextBlock Text="Personalized Playlists"
                                    Foreground="{StaticResource TextPrimary}"
                                    FontSize="20" FontWeight="Bold"
                                    Margin="0,12,0,10"/>

                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Hidden"
                                      Style="{StaticResource HorizScrollViewer}">
                            <ItemsControl x:Name="listPlaylists">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Width="130" Margin="0,0,16,8" Cursor="Hand">
                                            <Border Width="120" Height="120" CornerRadius="8"
                                                    Background="{StaticResource CardBg}"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                                                    <TextBlock Text="♪" FontSize="36"
                                                                Foreground="{StaticResource TextSecondary}"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="{Binding Name}"
                                                        Foreground="{StaticResource TextPrimary}"
                                                        FontSize="13" FontWeight="SemiBold"
                                                        TextTrimming="CharacterEllipsis"
                                                        Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding Creator}"
                                                        Foreground="{StaticResource TextSecondary}"
                                                        FontSize="12"
                                                        TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                    </StackPanel>
                </ScrollViewer>

                <!-- Дясна: Events -->
                <Border Grid.Column="1" Background="{StaticResource CardBg}"
                        CornerRadius="10" Margin="8,12,16,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Events"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="18" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,8"/>

                        <Border Grid.Row="1" ClipToBounds="True" CornerRadius="6"
                                Margin="8,0,8,0">
                            <Image x:Name="imgEvent" Stretch="UniformToFill"/>
                        </Border>

                        <Grid Grid.Row="2" Margin="8,8,8,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="❮"
                                    Style="{StaticResource ArrowBtn}"
                                    Foreground="{StaticResource TextPrimary}"
                                    FontSize="11"
                                    Click="btnEventPrev_Click"/>
                            <TextBlock Grid.Column="1" x:Name="txtEventTitle"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="10" TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="4,0"/>
                            <Button Grid.Column="2" Content="❯"
                                    Style="{StaticResource ArrowBtn}"
                                    Foreground="{StaticResource TextPrimary}"
                                    FontSize="11"
                                    Click="btnEventNext_Click"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── PLAYER BAR ── -->
            <Border Grid.Row="2" Height="90" Background="{StaticResource PlayerBg}" CornerRadius="0,0,12,12">
                <Grid Margin="20,0,20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <!-- Song info -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="60" Height="60" CornerRadius="6"
                    Background="{StaticResource CardBg}" Margin="0,0,12,0">
                            <TextBlock Text="♪" FontSize="26"
                           Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="No song playing"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="---"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="13"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Controls -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,-12,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,0,0,2">
                            <Button Style="{StaticResource NavBtn}">
                                <TextBlock Text="⇄" FontSize="20" Foreground="{StaticResource TextSecondary}"/>
                            </Button>
                            <Button Style="{StaticResource NavBtn}">
                                <TextBlock Text="⏮" FontSize="20" Foreground="{StaticResource TextSecondary}"/>
                            </Button>
                            <Button Style="{StaticResource NavBtn}">
                                <TextBlock Text="⏸" FontSize="26" Foreground="{StaticResource TextPrimary}"/>
                            </Button>
                            <Button Style="{StaticResource NavBtn}">
                                <TextBlock Text="⏭" FontSize="20" Foreground="{StaticResource TextSecondary}"/>
                            </Button>
                            <Button Style="{StaticResource NavBtn}">
                                <TextBlock Text="↺" FontSize="20" Foreground="{StaticResource TextSecondary}"/>
                            </Button>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="44"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="44"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="0:00"
                                        Foreground="{StaticResource TextSecondary}"
                                        FontSize="12" HorizontalAlignment="Right"
                                        VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Border Grid.Column="1" Height="4" CornerRadius="2"
                                    Background="#2A2E45" VerticalAlignment="Center">
                                <Border Width="0" Height="4" CornerRadius="2"
                                        Background="{StaticResource AccentBlue}"
                                        HorizontalAlignment="Left"/>
                            </Border>
                            <TextBlock Grid.Column="2" Text="0:00"
                                        Foreground="{StaticResource TextSecondary}"
                                        FontSize="12" HorizontalAlignment="Left"
                                        VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </StackPanel>

                    <!-- Volume -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                    VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Text="🔊" FontSize="20"
                       Foreground="{StaticResource TextSecondary}"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Border Height="4" Width="120" CornerRadius="2"
                    Background="#2A2E45" VerticalAlignment="Center">
                            <Border Width="70" Height="4" CornerRadius="2"
                        Background="{StaticResource AccentBlue}"
                        HorizontalAlignment="Left"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>