<Window x:Class="Zen_Music.HomePageMain"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Home Page Main"
        Width="820" Height="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="BgMain"        Color="#1A1D2E"/>
        <SolidColorBrush x:Key="BgNav"         Color="#12141F"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#8EBBFF"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#EAEAF5"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#7B80A8"/>
        <SolidColorBrush x:Key="CardBg"        Color="#22263A"/>
        <SolidColorBrush x:Key="PlayerBg"      Color="#12141F"/>

        <!-- Nav бутон -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2E45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Arrow бутон за Events -->
        <Style x:Key="ArrowBtn" TargetType="Button">
            <Setter Property="Background"      Value="#2A2E45"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="22"/>
            <Setter Property="Height"          Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="11">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slim ScrollBar -->
        <Style x:Key="SlimScrollBar" TargetType="ScrollBar">
            <Setter Property="Height"     Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="2" Background="#3D4270" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HorizScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Row="0"/>
                            <ScrollBar Grid.Row="1"
                                       Style="{StaticResource SlimScrollBar}"
                                       Orientation="Horizontal"
                                       Value="{TemplateBinding HorizontalOffset}"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgMain}" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <!-- ── NAV BAR ── -->
            <Border Grid.Row="0" Background="{StaticResource BgNav}" CornerRadius="12,12,0,0">
                <Grid Margin="16,0,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <TextBlock Grid.Column="0" Text="ZEN"
                               Foreground="{StaticResource AccentBlue}"
                               FontSize="18" FontWeight="Bold"
                               VerticalAlignment="Center"
                               />

                    <!-- Search -->
                    <Border Grid.Column="1" Background="#DDDCDC" CornerRadius="16"
                            Height="28" Width="200" HorizontalAlignment="Center">
                        <Grid Margin="10,0,8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Background="Transparent" BorderThickness="0"
                                     KeyDown="txtSearch_KeyDown"
                                     Foreground="#22263A"
                                     FontSize="12" VerticalContentAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="🔍" FontSize="12"
                                       Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center"/>

                        </Grid>
                    </Border>

                    <!-- Icons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource NavBtn}">
                            <TextBlock Text="🗄" FontSize="16" Foreground="{StaticResource TextSecondary}"/>
                        </Button>
                        <Button Style="{StaticResource NavBtn}">
                            <TextBlock Text="👥" FontSize="16" Foreground="{StaticResource TextSecondary}"/>
                        </Button>

                        <Button Style="{StaticResource NavBtn}" Click="btnProfile_Click">
                            <TextBlock Text="👤" FontSize="16" Foreground="{StaticResource TextSecondary}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── CONTENT ── -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>

                <!-- Лява: For You + Trending -->
                <ScrollViewer Grid.Column="0"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              Margin="16,12,8,8">
                    <StackPanel>

                        <!-- For You -->
                        <TextBlock Text="For You"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="16" FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Hidden"
                                      Style="{StaticResource HorizScrollViewer}">
                            <ItemsControl x:Name="listForYou">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Width="90" Margin="0,0,12,8" Cursor="Hand">
                                            <Border Width="82" Height="82" CornerRadius="6"
                                                    Background="{StaticResource CardBg}"
                                                    ClipToBounds="True">
                                                <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                                            </Border>
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding Artist}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="10"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Trending -->
                        <TextBlock Text="Trending"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="16" FontWeight="Bold"
                                   Margin="0,12,0,10"/>

                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Hidden"
                                      Style="{StaticResource HorizScrollViewer}">
                            <ItemsControl x:Name="listTrending">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Width="90" Margin="0,0,12,8" Cursor="Hand">
                                            <Border Width="82" Height="82" CornerRadius="6"
                                                    Background="{StaticResource CardBg}"
                                                    ClipToBounds="True">
                                                <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                                            </Border>
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding Artist}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="10"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                    </StackPanel>
                </ScrollViewer>

                <!-- Дясна: Events -->
                <Border Grid.Column="1" Background="{StaticResource CardBg}"
                        CornerRadius="10" Margin="8,12,16,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Events"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="14" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,8"/>

                        <Border Grid.Row="1" ClipToBounds="True" CornerRadius="6"
                                Margin="8,0,8,0">
                            <Image x:Name="imgEvent" Stretch="UniformToFill"/>
                        </Border>

                        <Grid Grid.Row="2" Margin="8,8,8,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="❮"
                                    Style="{StaticResource ArrowBtn}"
                                    Foreground="{StaticResource TextPrimary}"
                                    FontSize="11"
                                    Click="btnEventPrev_Click"/>
                            <TextBlock Grid.Column="1" x:Name="txtEventTitle"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="10" TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="4,0"/>
                            <Button Grid.Column="2" Content="❯"
                                    Style="{StaticResource ArrowBtn}"
                                    Foreground="{StaticResource TextPrimary}"
                                    FontSize="11"
                                    Click="btnEventNext_Click"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── PLAYER BAR ── -->
            <Border Grid.Row="2" Background="{StaticResource PlayerBg}" CornerRadius="0,0,12,12">
                <Grid Margin="16,0,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <!-- Song info -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="40" Height="40" CornerRadius="4"
                                Background="{StaticResource CardBg}" Margin="0,0,10,0">
                            <TextBlock Text="♪" FontSize="18"
                                       Foreground="{StaticResource TextSecondary}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="No song playing"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Text="---"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="11"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Controls -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Margin="0,0,0,4">
                            <Button Style="{StaticResource NavBtn}">
                                <TextBlock Text="⇄" FontSize="14" Foreground="{StaticResource TextSecondary}"/>
                            </Button>
                            <Button Style="{StaticResource NavBtn}">
                                <TextBlock Text="⏮" FontSize="14" Foreground="{StaticResource TextSecondary}"/>
                            </Button>
                            <Button Style="{StaticResource NavBtn}">
                                <TextBlock Text="⏸" FontSize="18" Foreground="{StaticResource TextPrimary}"/>
                            </Button>
                            <Button Style="{StaticResource NavBtn}">
                                <TextBlock Text="⏭" FontSize="14" Foreground="{StaticResource TextSecondary}"/>
                            </Button>
                            <Button Style="{StaticResource NavBtn}">
                                <TextBlock Text="↺" FontSize="14" Foreground="{StaticResource TextSecondary}"/>
                            </Button>
                        </StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="0:00"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="10" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <Border Grid.Column="1" Height="3" CornerRadius="2"
                                    Background="#2A2E45" VerticalAlignment="Center">
                                <Border Width="0" Height="3" CornerRadius="2"
                                        Background="{StaticResource AccentBlue}"
                                        HorizontalAlignment="Left"/>
                            </Border>
                            <TextBlock Grid.Column="2" Text="0:00"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="10" HorizontalAlignment="Left"
                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </Grid>
                    </StackPanel>

                    <!-- Volume -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Text="🔊" FontSize="13"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Border Height="3" Width="70" CornerRadius="2"
                                Background="#2A2E45" VerticalAlignment="Center">
                            <Border Width="50" Height="3" CornerRadius="2"
                                    Background="{StaticResource AccentBlue}"
                                    HorizontalAlignment="Left"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>