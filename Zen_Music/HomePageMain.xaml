<Window x:Class="Zen_Music.HomePageMain"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Home Page Main"
        Width="1440" Height="900"
        MinWidth="1024" MinHeight="768"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        KeyDown="Window_KeyDown"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <SolidColorBrush x:Key="BgMain"        Color="#1A1D2E"/>
        <SolidColorBrush x:Key="BgNav"         Color="#12141F"/>
        <SolidColorBrush x:Key="AccentBlue"    Color="#8EBBFF"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#EAEAF5"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#7B80A8"/>
        <SolidColorBrush x:Key="CardBg"        Color="#22263A"/>
        <SolidColorBrush x:Key="PlayerBg"      Color="#12141F"/>

        <!-- Nav бутон -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2E45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Arrow бутон за Events -->
        <Style x:Key="ArrowBtn" TargetType="Button">
            <Setter Property="Background"      Value="#2A2E45"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="26"/>
            <Setter Property="Height"          Value="26"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="13">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBlue}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgMain}" CornerRadius="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── NAV BAR ── -->
            <Border x:Name="HeaderPanel" Height="70" Grid.Row="0" Background="{StaticResource BgNav}" CornerRadius="12,12,0,0">
                <Grid Margin="20,0,20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <TextBlock Grid.Column="0" Text="ZEN"
                               Foreground="{StaticResource AccentBlue}"
                               FontSize="22" FontWeight="Bold"
                               VerticalAlignment="Center" Cursor="Hand" MouseDown="txtZen_Click"/>

                    <!-- Search -->
                    <Border Grid.Column="1" Background="#DDDCDC" CornerRadius="18"
                            Height="40" Width="420" HorizontalAlignment="Center">
                        <Grid Margin="12,0,10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Background="Transparent" BorderThickness="0"
                                     KeyDown="txtSearch_KeyDown"
                                     Foreground="#22263A"
                                     FontSize="14" VerticalContentAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="🔍" FontSize="16"
                                       Foreground="{StaticResource TextSecondary}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Icons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource NavBtn}">
                            <TextBlock Text="🗄" FontSize="22" Foreground="{StaticResource TextSecondary}"/>
                        </Button>
                        <Button Style="{StaticResource NavBtn}">
                            <TextBlock Text="👥" FontSize="22" Foreground="{StaticResource TextSecondary}"/>
                        </Button>
                        <Button Style="{StaticResource NavBtn}" Click="btnProfile_Click">
                            <TextBlock Text="👤" FontSize="22" Foreground="{StaticResource TextSecondary}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── CONTENT ── -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <!-- Лява: For You + Trending -->
                <ScrollViewer Grid.Column="0"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              PreviewMouseWheel="LeftPanel_PreviewMouseWheel"
                              Margin="24,20,12,12">
                    <StackPanel>

                        <!-- For You -->
                        <TextBlock Text="For You"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="26" FontWeight="Bold"
                                   Margin="0,0,0,16"/>

                        <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled"
                                      PreviewMouseWheel="ForYou_PreviewMouseWheel">
                            <ItemsControl x:Name="listForYou">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Width="180"
                                        Margin="0,0,24,12"
                                        Cursor="Hand"
                                        MouseDown="SongCard_Click">
                                            <Border Width="170" Height="170" CornerRadius="12"
                                                    Background="{StaticResource CardBg}"
                                                    ClipToBounds="True">
                                                <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                                            </Border>
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="16" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,8,0,0"/>
                                            <TextBlock Text="{Binding Artist}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="14"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Trending -->
                        <TextBlock Text="Trending"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="26" FontWeight="Bold"
                                   Margin="0,20,0,16"/>

                        <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled"
                                      PreviewMouseWheel="Trending_PreviewMouseWheel">
                            <ItemsControl x:Name="listTrending">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Width="180"
            Margin="0,0,24,12"
            Cursor="Hand"
            MouseDown="SongCard_Click">
                                            <Border Width="170" Height="170" CornerRadius="12"
                                                    Background="{StaticResource CardBg}"
                                                    ClipToBounds="True">
                                                <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                                            </Border>
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="16" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,8,0,0"/>
                                            <TextBlock Text="{Binding Artist}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="14"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Personalized Playlists -->
                        <TextBlock Text="Personalized Playlists"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="26" FontWeight="Bold"
                                   Margin="0,20,0,16"/>

                        <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled"
                                      PreviewMouseWheel="Playlists_PreviewMouseWheel">
                            <ItemsControl x:Name="listPlaylists">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Width="180" Margin="0,0,24,12" Cursor="Hand">
                                            <Border Width="170" Height="170" CornerRadius="12"
                                                    Background="{StaticResource CardBg}"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding Cover}" Stretch="UniformToFill"/>
                                                    <TextBlock Text="♪" FontSize="50"
                                                               Foreground="{StaticResource TextSecondary}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="16" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,8,0,0"/>
                                            <TextBlock Text="{Binding Creator}"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       FontSize="14"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                    </StackPanel>
                </ScrollViewer>

                <!-- Дясна: Events -->
                <Border Grid.Column="1" Background="{StaticResource CardBg}"
                        CornerRadius="14" Margin="12,20,24,24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Events"
                                   Foreground="{StaticResource TextPrimary}"
                                   FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,16,0,12"/>

                        <Border Grid.Row="1" ClipToBounds="True" CornerRadius="8"
                                Margin="16,0,16,0">
                            <Image x:Name="imgEvent" Stretch="UniformToFill"/>
                        </Border>

                        <Grid Grid.Row="2" Margin="16,12,16,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="❮"
                                    Style="{StaticResource ArrowBtn}"
                                    Foreground="{StaticResource TextPrimary}"
                                    FontSize="14"
                                    Click="btnEventPrev_Click"/>
                            <TextBlock Grid.Column="1" x:Name="txtEventTitle"
                                       Foreground="{StaticResource TextSecondary}"
                                       FontSize="14" TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="8,0"/>
                            <Button Grid.Column="2" Content="❯"
                                    Style="{StaticResource ArrowBtn}"
                                    Foreground="{StaticResource TextPrimary}"
                                    FontSize="14"
                                    Click="btnEventNext_Click"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── PLAYER BAR ── -->
            <Border Grid.Row="2"
        Height="100"
        Background="{StaticResource PlayerBg}"
        CornerRadius="0,0,12,12">

                <Grid Margin="24,0,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <!-- Song info -->
                    <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">

                        <!-- COVER -->
                        <Border Width="70"
                    Height="70"
                    CornerRadius="8"
                    Background="{StaticResource CardBg}"
                    Margin="0,0,16,0"
                    ClipToBounds="True">

                            <Image x:Name="imgPlayerCover"
                       Stretch="UniformToFill"/>
                        </Border>

                        <!-- SONG INFO -->
                        <StackPanel VerticalAlignment="Center">

                            <TextBlock x:Name="txtPlayerTitle"
                           Text="No song playing"
                           Foreground="{StaticResource TextPrimary}"
                           FontSize="18"
                           FontWeight="SemiBold"/>

                            <TextBlock x:Name="txtPlayerArtist"
                           Text="---"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="14"
                           Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- CONTROLS -->
                    <StackPanel Grid.Column="1"
                    VerticalAlignment="Center"
                    Margin="0,-8,0,0">

                        <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,6">

                            <Button Style="{StaticResource NavBtn}" Margin="4,0">
                                <TextBlock Text="⇄"
                               FontSize="22"
                               Foreground="{StaticResource TextSecondary}"/>
                            </Button>

                            <Button Style="{StaticResource NavBtn}" Margin="4,0">
                                <TextBlock Text="⏮"
                               FontSize="22"
                               Foreground="{StaticResource TextSecondary}"/>
                            </Button>

                            <!-- PLAY / PAUSE -->
                            <Button Style="{StaticResource NavBtn}"
                        Margin="8,0"
                        Click="btnPlayPause_Click">

                                <TextBlock x:Name="txtPlayPause"
                               Text="▶"
                               FontSize="32"
                               Foreground="{StaticResource TextPrimary}"/>
                            </Button>

                            <Button Style="{StaticResource NavBtn}" Margin="4,0">
                                <TextBlock Text="⏭"
                               FontSize="22"
                               Foreground="{StaticResource TextSecondary}"/>
                            </Button>

                            <Button Style="{StaticResource NavBtn}" Margin="4,0">
                                <TextBlock Text="↺"
                               FontSize="22"
                               Foreground="{StaticResource TextSecondary}"/>
                            </Button>
                        </StackPanel>

                        <!-- PROGRESS BAR -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                           x:Name="txtCurrentTime"
                           Text="0:00"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="13"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>

                            <!-- BAR -->
                            <Border Grid.Column="1"
                        x:Name="progressBackground"
                        Height="6"
                        CornerRadius="3"
                        Background="#2A2E45"
                        VerticalAlignment="Center"
                        MouseDown="progressBackground_MouseDown">

                                <Border x:Name="progressFill"
                            Width="0"
                            Height="6"
                            CornerRadius="3"
                            Background="{StaticResource AccentBlue}"
                            HorizontalAlignment="Left"/>
                            </Border>

                            <TextBlock Grid.Column="2"
                           x:Name="txtTotalTime"
                           Text="0:00"
                           Foreground="{StaticResource TextSecondary}"
                           FontSize="13"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
                        </Grid>
                    </StackPanel>

                    <!-- VOLUME -->
                    <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right">

                        <TextBlock Text="🔊"
                       FontSize="22"
                       Foreground="{StaticResource TextSecondary}"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"/>

                        <Border Height="6"
                    Width="140"
                    CornerRadius="3"
                    Background="#2A2E45"
                    VerticalAlignment="Center">

                            <Border Width="80"
                        Height="6"
                        CornerRadius="3"
                        Background="{StaticResource AccentBlue}"
                        HorizontalAlignment="Left"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>